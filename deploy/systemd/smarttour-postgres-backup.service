[Unit]
Description=SmartTour daily PostgreSQL backup
After=docker.service

[Service]
Type=oneshot
UMask=0027
EnvironmentFile=-/etc/default/smarttour-ops
WorkingDirectory=/opt/smarttour
ExecStart=/opt/smarttour/scripts/backup-postgres.sh
TimeoutStartSec=45min
StandardOutput=append:/var/log/smarttour/postgres-backup.log
StandardError=append:/var/log/smarttour/postgres-backup.log
