{
  "name": "smarttour",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "smoke:rbac": "scripts/smoke-rbac-workflows.sh",
    "smoke:business": "scripts/smoke-business-workflows.sh",
    "smoke:core": "scripts/smoke-core-business-workflows.sh",
    "smoke:operations": "scripts/smoke-operations-backend.sh",
    "smoke:operations:ui": "node scripts/smoke-operations-ui.js",
    "smoke:quotes": "bash scripts/smoke-quotes-quotations.sh",
    "test:quotes:backend": "node scripts/test-quotes-backend-contract.js",
    "test:quotes:coverage": "node scripts/test-quotes-test-coverage-contract.js",
    "test:quotes:combo-client": "node scripts/test-quote-combos-client-contract.js",
    "test:quotes:tour-client": "node scripts/test-quote-tours-client-contract.js",
    "test:quotations:client": "node scripts/test-quotations-client-contract.js",
    "smoke:suppliers": "scripts/smoke-suppliers.sh",
    "smoke:finance": "scripts/smoke-finance-reports.sh",
    "smoke:files": "scripts/smoke-files.sh",
    "smoke:reports": "scripts/smoke-reports-business-rules.sh",
    "smoke:exports": "scripts/smoke-exports.sh",
    "smoke:ui": "scripts/smoke-ui-pages.sh",
    "smoke:ui:browser": "node scripts/smoke-ui-browser.js",
    "smoke:ui:interactions": "node scripts/smoke-ui-interactions.js",
    "smoke:ux-ui": "scripts/smoke-ux-ui.sh",
    "test:suppliers:hotel-client": "scripts/test-suppliers-hotel-client-ui.sh",
    "test:suppliers:generic": "scripts/test-suppliers-generic.sh",
    "test:suppliers:hotel": "scripts/test-suppliers-hotel.sh",
    "test:core-workflows": "scripts/test-core-business-workflows-contract.sh",
    "test:ux-ui": "scripts/test-ux-ui-contract.sh",
    "test:role-permissions": "node scripts/test-role-permission-contract.js",
    "test:data-scope": "node scripts/test-data-scope-contract.js && scripts/test-data-scope-module-flows.sh && scripts/test-data-scope-api-flows.sh",
    "test:list-table-compact": "node scripts/audit-list-table-compact.js",
    "test:web-server-api-base": "node scripts/test-web-server-api-base-contract.js",
    "test:required-fields-ui": "node scripts/test-required-fields-ui-contract.js",
    "test:localized-dropdowns": "node scripts/test-localized-dropdowns-contract.js",
    "smoke:data-scope": "scripts/verify-data-scope.sh",
    "smoke:all": "npm run smoke:rbac && npm run smoke:business && npm run smoke:operations && npm run smoke:suppliers && npm run smoke:finance && npm run smoke:files && npm run smoke:reports && npm run smoke:exports && npm run smoke:ui && npm run smoke:ui:browser && npm run smoke:ui:interactions",
    "ops:health": "scripts/healthcheck.sh",
    "ops:security": "scripts/security-audit.sh",
    "ops:backup": "scripts/backup-postgres.sh",
    "ops:disaster-backup": "scripts/disaster-backup.sh",
    "ops:backup-sync": "scripts/sync-latest-backup.sh",
    "ops:restore-drill": "scripts/restore-drill-postgres.sh",
    "ops:install-schedule": "scripts/install-ops-schedule.sh",
    "deploy:preview": "scripts/deploy-preview.sh",
    "verify:deploy": "npx prisma migrate status && scripts/smartlink-legacy-audit.sh --mode=guard && npm audit --omit=dev && npm run smoke:all && npm run ops:health && npm run ops:security",
    "test:fit-wizard": "scripts/test-fit-wizard-ui-contract.sh",
    "verify:toolchain": "scripts/verify-toolchain-docker.sh",
    "ops:smartlink:audit": "scripts/smartlink-legacy-audit.sh --mode=audit",
    "ops:smartlink:backfill": "scripts/smartlink-legacy-audit.sh --mode=backfill",
    "test:observability-alerting": "node scripts/test-observability-alerting-contract.js",
    "test:backup-offsite": "node scripts/test-backup-offsite-contract.js",
    "test:security-audit": "node scripts/test-security-audit-contract.js",
    "test:smoke-files-command": "node scripts/test-smoke-files-command-contract.js",
    "test:ops-schedule-docs": "node scripts/test-ops-schedule-docs-contract.js",
    "test:rollback-runbook": "node scripts/test-rollback-runbook-contract.js",
    "test:restore-drill-safety": "node scripts/test-restore-drill-safety-contract.js"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    },
    "@nestjs/swagger": {
      "js-yaml": "4.2.0"
    }
  }
}
