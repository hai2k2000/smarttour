  actor       String?
  createdAt   DateTime          @default(now())

  @@index([allotmentId])
  @@index([supplierId])
}

model SupplierFile {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String?
  uploadedBy String?
