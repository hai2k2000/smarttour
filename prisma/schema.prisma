model Customer {
  id              String                @id @default(uuid())
  code            String                @unique
  status          CustomerStatus        @default(ACTIVE)
  typeId          String?
  type            CustomerTypeConfig?   @relation(fields: [typeId], references: [id], onDelete: SetNull)
  kind            String                @default("INDIVIDUAL")
  fullName        String
  gender          String?
  dateOfBirth     DateTime?
  phone           String                @unique
  email           String?
  facebookUrl     String?
  zaloUrl         String?
  address         String?
  province        String?
  country         String?
  taxCode         String?
  companyName     String?
  tradingName     String?
  website         String?
  companyAddress  String?
  source          String?
  market          String?
  groupName       String?
  campaignId      String?
  campaign        CustomerCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy       String?
  owner           String?
  branch          String?
  department      String?
  agencyType      String?
  collaborator    String?
  latestComment   String?
  mergedIntoId    String?
  mergedInto      Customer?             @relation("CustomerMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedCustomers Customer[]            @relation("CustomerMerge")
  tags            CustomerTagMap[]
  contacts        CustomerContact[]
  timeline        CustomerTimeline[]
  careTasks       CustomerCareTask[]
  comments        CustomerComment[]
  callLogs        CustomerCallLog[]
  opportunities   CustomerOpportunity[]
  files           CustomerFile[]
  orders          Order[]
  bookings        Booking[]
  tourCustomers   TourCustomer[]
  tourQuotes      TourQuote[]
  quotations      Quotation[]
  financeReceipts FinanceReceipt[]
  financeInvoices FinanceInvoice[]
  cashflowEntries FinanceCashflowEntry[]
  customerLedger  CustomerLedgerEntry[]
  fitTours        FitTour[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
  @@index([typeId])
  @@index([owner])
  @@index([branch])
  @@index([department])
  @@index([market])
  @@index([campaignId])
  @@index([createdAt])
  @@index([status, createdAt], map: "idx_customer_status_created")
  @@index([branch, department, status, createdAt], map: "idx_customer_scope_status_created")
  @@index([owner, createdAt], map: "idx_customer_owner_created")
}

model CustomerFile {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerTagMap {
