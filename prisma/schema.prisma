  budgetUnitPrice    Decimal           @default(0)
  confirmedUnitPrice Decimal           @default(0)
  vat                Decimal           @default(0)
  salesAmount        Decimal           @default(0)
  budgetAmount       Decimal           @default(0)
  confirmedAmount    Decimal           @default(0)
  confirmationStatus TourServiceStatus @default(WAITING)
  bookingCode        String?
  notes              String?
  costs              TourCost[]

  @@index([supplierServiceId])
