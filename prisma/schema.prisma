  cost          TourCost?     @relation(fields: [costId], references: [id])
  code          String?
  amount        Decimal       @default(0)
  currency      String        @default("VND")
  paymentStatus PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  notes         String?
