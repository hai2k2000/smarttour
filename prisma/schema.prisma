/// Legacy compatibility snapshot for FIT uploaded file metadata. Canonical value is TourAttachment; upload endpoint may append this snapshot for compatibility, while autosave/update must not own attachments.
model FitAttachment {
  id        String   @id @default(uuid())
  fitTourId String
  fitTour   FitTour  @relation(fields: [fitTourId], references: [id], onDelete: Cascade)
  step      String?
  fileName  String
  fileUrl   String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model OperationForm {
  id        String             @id @default(uuid())
  bookingId String             @unique
  booking   Booking            @relation(fields: [bookingId], references: [id])
  orderId   String?
  order     Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tourId    String?
  tour      Tour?              @relation(fields: [tourId], references: [id], onDelete: SetNull)
  status    OperationStatus    @default(PENDING)
  notes     String?
  services  OperationService[]
  tasks     OperationTask[]
  costs     OperationCost[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([orderId])
  @@index([tourId])
  @@index([status, updatedAt], map: "idx_operation_form_status_updated")
  @@index([updatedAt, createdAt], map: "idx_operation_form_updated_created")
}

model OperationService {
  id                 String            @id @default(uuid())
  operationFormId    String
  operationForm      OperationForm     @relation(fields: [operationFormId], references: [id])
  itineraryDayId     String?
  itineraryDay       TourItineraryDay? @relation(fields: [itineraryDayId], references: [id])
  supplierId         String?
  supplier           Supplier?         @relation(fields: [supplierId], references: [id])
  supplierServiceId  String?
  supplierService    SupplierService?  @relation(fields: [supplierServiceId], references: [id], onDelete: SetNull)
  serviceType        String
  serviceName        String
  confirmationStatus String            @default("WAITING")
  expectedCost       Decimal           @default(0)
  actualCost         Decimal           @default(0)
  notes              String?
  costs              OperationCost[]

  @@index([supplierServiceId])
  @@index([operationFormId], map: "idx_operation_service_form")
  @@index([operationFormId, confirmationStatus], map: "idx_operation_service_form_confirm")
}

model OperationTask {
  id              String          @id @default(uuid())
  operationFormId String
  operationForm   OperationForm   @relation(fields: [operationFormId], references: [id])
  title           String
  assignee        String?
  dueDate         DateTime?
  status          OperationStatus @default(PENDING)
  notes           String?

  @@index([operationFormId], map: "idx_operation_task_form")
  @@index([operationFormId, status, dueDate], map: "idx_operation_task_form_status_due")
  @@index([status, dueDate], map: "idx_operation_task_status_due")
}

model OperationCost {
  id              String                @id @default(uuid())
  operationFormId String
  operationForm   OperationForm         @relation(fields: [operationFormId], references: [id])
  serviceId       String?
  service         OperationService?     @relation(fields: [serviceId], references: [id])
  costName        String
  expectedAmount  Decimal               @default(0)
  actualAmount    Decimal               @default(0)
  currency        String                @default("VND")
  invoiceNo       String?
  notes           String?
  paymentItems    SupplierPaymentItem[]

  @@index([operationFormId], map: "idx_operation_cost_form")
  @@index([serviceId], map: "idx_operation_cost_service")
}

model SupplierPaymentRequest {
  id          String                @id @default(uuid())
  code        String                @unique
  status      SupplierPaymentStatus @default(DRAFT)
  financePaymentId String?
  financePayment   FinancePayment?         @relation(fields: [financePaymentId], references: [id], onDelete: SetNull)
  requestedBy String?
  approvedBy  String?
  requestedAt DateTime              @default(now())
  items       SupplierPaymentItem[]

  @@index([financePaymentId])
  @@index([status, requestedAt], map: "idx_supplier_payment_request_status_requested")
  @@index([requestedAt, code], map: "idx_supplier_payment_request_requested_code")
}

model SupplierPaymentItem {
  id         String                 @id @default(uuid())
  requestId  String
  request    SupplierPaymentRequest @relation(fields: [requestId], references: [id])
  supplierId String
  supplier   Supplier               @relation(fields: [supplierId], references: [id])
  costId     String?
  cost       OperationCost?         @relation(fields: [costId], references: [id])
  amount     Decimal                @default(0)
  notes      String?

  @@index([requestId], map: "idx_supplier_payment_item_request")
  @@index([supplierId], map: "idx_supplier_payment_item_supplier")
  @@index([costId], map: "idx_supplier_payment_item_cost")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
