  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  fileName   String?
  fileUrl    String?
  mentions   String[]
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt], map: "idx_customer_comment_customer_created")
}

model CustomerCallLog {
