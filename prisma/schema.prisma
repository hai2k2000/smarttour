  serviceId          String?
  service            SupplierService?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  sku                String?
  serviceName        String
  startDate          DateTime?
  endDate            DateTime?
  dayType            SupplierDayType        @default(ALL_DAYS)
  allotmentQty       Int                    @default(0)
  bookedQty          Int                    @default(0)
  lockedQty          Int                    @default(0)
  quantityLock       Int                    @default(0)
  cutoffDays         Int                    @default(0)
  netCostPerDay      Decimal                @default(0)
  sellingPricePerDay Decimal                @default(0)
  status             String                 @default("ACTIVE")
  description        String?
  note               String?
  logs               SupplierAllotmentLog[]
  allocations        SupplierAllotmentAllocation[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([supplierId, sku])
  @@index([status])
  @@index([startDate, endDate])
}

model SupplierAllotmentAllocation {
  id          String            @id @default(uuid())
  allotmentId String
  allotment   SupplierAllotment @relation(fields: [allotmentId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     SupplierService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  orderOperationItemId String?
  orderOperationItem   OrderOperationItem? @relation(fields: [orderOperationItemId], references: [id], onDelete: SetNull)
  orderId     String?
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bookingId   String?
  booking     Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  tourId      String?
  tour        Tour?             @relation(fields: [tourId], references: [id], onDelete: SetNull)
  quantity    Int               @default(1)
  status      String            @default("LOCKED")
  lockedAt    DateTime?
  confirmedAt DateTime?
  releasedAt  DateTime?
  note        String?
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([allotmentId, status])
  @@index([supplierId])
  @@index([serviceId])
  @@index([orderOperationItemId])
  @@index([orderId])
  @@index([bookingId])
  @@index([tourId])
}

model SupplierAllotmentLog {
  id          String            @id @default(uuid())
  allotmentId String
  allotment   SupplierAllotment @relation(fields: [allotmentId], references: [id], onDelete: Cascade)
