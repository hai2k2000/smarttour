generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  OPERATING
  COMPLETED
  CANCELLED
}

enum OperationStatus {
  PENDING
  IN_PROGRESS
  DONE
  PROBLEM
  CANCELLED
}

enum SupplierPaymentStatus {
  DRAFT
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum TourType {
  FIT
  GIT
  LANDTOUR
}

enum TourStatus {
  DRAFT
  UPCOMING
  RUNNING
  COMPLETED
  CANCELLED
  SETTLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUND
}

enum TourServiceStatus {
  WAITING
  REQUESTED
  CONFIRMED
  OPERATING
  COMPLETED
  CANCELLED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum SupplierDayType {
  ALL_DAYS
  WEEKDAY
  WEEKEND
  HOLIDAY
  PEAK
}

enum FitTourWorkflowStatus {
  DRAFT
  PRICING
  TOUR_INFO
  BUDGET
  OPERATION
  HANDOVER
  SURVEY
  COMPLETED
  CANCELLED
}

enum FitServiceStatus {
  WAITING
  REQUESTED
  CONFIRMED
  OPERATING
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

enum QuoteCostType {
  COMMON
  HOTEL
  PRIVATE
}

enum QuoteComboStatus {
  DRAFT
  QUOTED
  ORDER_CREATED
  CANCELLED
}

enum QuotationProductType {
  FIT
  GIT
  LANDTOUR
  COMBO
  BOOKING
  VISA
  SERVICE
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum OrderType {
  FIT_TOUR
  GIT_COMBO
  LANDTOUR
  HOTEL_BOOKING
  SINGLE_SERVICE
  FLIGHT_ORDER
}

enum OperationVoucherStatus {
  PENDING
  PARTIAL
  PAID
}

enum OrderStatus {
  DRAFT
  UPCOMING
  RUNNING
  COMPLETED
  CANCELLED
  SETTLED
}

enum OrderPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUND
}

enum OrderCostStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum OrderServiceStatus {
  WAITING
  REQUESTED
  CONFIRMED
  OPERATING
  COMPLETED
  CANCELLED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  MERGED
}

enum CommissionStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum CommissionPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum FinanceApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FinanceReceiptType {
  DEPOSIT
  TOUR_PAYMENT
  CUSTOMER_DEBT
  COLLECT_ON_BEHALF
  SUPPLIER_FUND_REFUND
  OTHER
}

enum FinancePaymentType {
  SUPPLIER_PAYMENT
  CUSTOMER_REFUND
  COMMISSION
  INTERNAL_EXPENSE
  SUPPLIER_DEPOSIT
  ADVANCE
  OTHER
}

enum FinancePaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  QR
  OFFSET
  OTHER
}

enum FinanceCashflowEntryType {
  RECEIPT
  PAYMENT
}

enum FinanceInvoiceStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FinanceInvoiceType {
  VAT
  NO_VAT
  ADJUSTMENT
  REPLACEMENT
}

enum LedgerEntryType {
  OPENING
  DEBIT
  CREDIT
  ADJUSTMENT
  REVERSAL
}

enum LedgerPartyType {
  CUSTOMER
  SUPPLIER
}

enum LedgerSourceType {
  ORDER
  OPERATION_VOUCHER
  FINANCE_RECEIPT
  FINANCE_PAYMENT
  FINANCE_INVOICE
  COMMISSION
  MANUAL
}

model User {
  id           String        @id @default(uuid())
  username     String?       @unique
  email        String        @unique
  name         String
  phone        String?
  gender       String?
  dateOfBirth  DateTime?
  address      String?
  identityNo   String?
  maritalStatus String?
  nationality  String?
  ethnicity    String?
  religion     String?
  taxCode      String?
  rank         String?
  bankAccountNumber String?
  bankAccountName   String?
  bankName          String?
  passwordHash String
  status       String        @default("ACTIVE")
  branch       String?
  department   String?
  lastLoginAt  DateTime?
  roles        UserRole[]
  sessions     UserSession[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([username])
  @@index([phone])
  @@index([branch])
  @@index([department])
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false)
  status      String           @default("ACTIVE")
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id         String   @id @default(uuid())
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([roleId, permission])
  @@index([permission])
}

model UserSession {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model TourQuote {
  id                 String           @id @default(uuid())
  quoteCode          String           @unique
  customerId         String?
  customer           Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tourCode           String
  tourName           String?
  route              String?
  marketGroup        String?
  currency           String           @default("VND")
  exchangeRate       Decimal          @default(1)
  bookingDate        DateTime?
  paymentDate        DateTime?
  departureDate      DateTime?
  returnDate         DateTime?
  customerName       String?
  customerPhone      String?
  customerEmail      String?
  customerAddress    String?
  customerNote       String?
  operatorOwner      String?
  collaborator       String?
  adultQty           Int              @default(1)
  childQty           Int              @default(0)
  infantQty          Int              @default(0)
  totalPax           Int              @default(1)
  commonCostTotal    Decimal          @default(0)
  privateCostTotal   Decimal          @default(0)
  netPrice           Decimal          @default(0)
  profit             Decimal          @default(0)
  commission         Decimal          @default(0)
  discount           Decimal          @default(0)
  sellingPrice       Decimal          @default(0)
  childPricePercent  Decimal          @default(75)
  childSellingPrice  Decimal          @default(0)
  infantPricePercent Decimal          @default(20)
  infantSellingPrice Decimal          @default(0)
  profitRate         Decimal          @default(0)
  status             QuoteStatus      @default(DRAFT)
  approvedBy         String?
  approvalNote       String?
  costItems          QuoteCostItem[]
  itineraries        QuoteItinerary[]
  createdBy          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status])
  @@index([departureDate])
  @@index([updatedAt], map: "idx_tour_quote_updated")
  @@index([status, updatedAt], map: "idx_tour_quote_status_updated")
}

model QuoteCostItem {
  id           String        @id @default(uuid())
  quoteId      String
  quote        TourQuote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  costType     QuoteCostType
  serviceType  String?
  description  String?
  unit         String?
  quantity     Decimal       @default(1)
  serviceCount Decimal       @default(1)
  paxPerRoom   Decimal       @default(1)
  currency     String        @default("VND")
  exchangeRate Decimal       @default(1)
  unitPrice    Decimal       @default(0)
  vat          Decimal       @default(0)
  amount       Decimal       @default(0)
  note         String?
  sortOrder    Int           @default(0)
}

model QuoteItinerary {
  id        String    @id @default(uuid())
  quoteId   String
  quote     TourQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  dayNo     Int
  title     String?
  content   String?
  sortOrder Int       @default(0)
}

model QuoteCombo {
  id                  String           @id @default(uuid())
  comboCode           String           @unique
  comboType           String
  note                String?
  totalNetPricePerPax Decimal          @default(0)
  profitPerPax        Decimal          @default(0)
  adultComboPrice     Decimal          @default(0)
  childPricePercent   Decimal          @default(75)
  childComboPrice     Decimal          @default(0)
  status              QuoteComboStatus @default(DRAFT)
  items               QuoteComboItem[]
  createdBy           String?
  branch              String?
  department          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status])
  @@index([branch])
  @@index([department])
}

model QuoteComboItem {
  id                 String           @id @default(uuid())
  comboId            String
  combo              QuoteCombo       @relation(fields: [comboId], references: [id], onDelete: Cascade)
  supplierId         String?
  supplier           Supplier?        @relation(fields: [supplierId], references: [id])
  serviceId          String?
  supplierService    SupplierService? @relation(fields: [serviceId], references: [id])
  serviceName        String
  checkIn            DateTime?
  netPricePerService Decimal          @default(0)
  nightCount         Decimal          @default(1)
  paxCount           Decimal          @default(1)
  netPricePerPax     Decimal          @default(0)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Quotation {
  id                  String                 @id @default(uuid())
  quoteCode           String                 @unique
  customerId          String?
  customer            Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  productType         QuotationProductType
  customerCode        String?
  customerName        String?
  customerPhone       String?
  customerEmail       String?
  salesOwner          String?
  operatorOwner       String?
  branch              String?
  department          String?
  marketGroup         String?
  productCategory     String?
  route               String?
  paxAdult            Int                    @default(1)
  paxChild            Int                    @default(0)
  paxInfant           Int                    @default(0)
  paxTotal            Int                    @default(1)
  currency            String                 @default("VND")
  exchangeRate        Decimal                @default(1)
  createdDate         DateTime?
  expiredDate         DateTime?
  expectedPaymentDate DateTime?
  departureDate       DateTime?
  returnDate          DateTime?
  approvalLevel       Int                    @default(0)
  status              QuotationStatus        @default(DRAFT)
  totalCost           Decimal                @default(0)
  totalMarkup         Decimal                @default(0)
  totalSelling        Decimal                @default(0)
  costPerPax          Decimal                @default(0)
  sellingPerPax       Decimal                @default(0)
  profitPerPax        Decimal                @default(0)
  marginRate          Decimal                @default(0)
  adultPrice          Decimal                @default(0)
  childPrice          Decimal                @default(0)
  infantPrice         Decimal                @default(0)
  smartLinkToken      String?                @unique
  smartLinkEnabled    Boolean                @default(false)
  language            String                 @default("VI")
  terms               String?
  note                String?
  convertedOrderId    String?
  items               QuotationItem[]
  logs                QuotationApprovalLog[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([productType, status])
  @@index([expiredDate])
  @@index([salesOwner])
  @@index([branch])
  @@index([updatedAt], map: "idx_quotation_updated")
  @@index([productType, status, updatedAt], map: "idx_quotation_product_status_updated")
}

model QuotationItem {
  id            String           @id @default(uuid())
  quotationId   String
  quotation     Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  serviceType   String
  supplierId    String?
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  serviceId     String?
  service       SupplierService? @relation(fields: [serviceId], references: [id])
  supplierName  String?
  serviceName   String
  unit          String?
  quantity      Decimal          @default(1)
  paxCount      Decimal          @default(1)
  nightCount    Decimal          @default(1)
  netPrice      Decimal          @default(0)
  vat           Decimal          @default(0)
  markupAmount  Decimal          @default(0)
  markupPercent Decimal          @default(0)
  sellingPrice  Decimal          @default(0)
  amount        Decimal          @default(0)
  note          String?
  sortOrder     Int              @default(0)
}

model QuotationApprovalLog {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  action      String
  actor       String?
  note        String?
  oldStatus   String?
  newStatus   String?
  createdAt   DateTime  @default(now())
}

model Order {
  id                String                @id @default(uuid())
  type              OrderType
  systemCode        String                @unique
  customerId        String?
  customer          Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tourCode          String?
  holdCode          String?
  name              String
  route             String?
  marketGroup       String?
  bookingDate       DateTime?
  paymentDate       DateTime?
  startDate         DateTime?
  endDate           DateTime?
  status            OrderStatus           @default(UPCOMING)
  paymentStatus     OrderPaymentStatus    @default(UNPAID)
  costStatus        OrderCostStatus       @default(PENDING)
  tourCategory      String?
  currency          String                @default("VND")
  exchangeRate      Decimal               @default(1)
  createdBy         String?
  createdDate       DateTime?
  accountCode       String?
  branch            String?
  department        String?
  customerName      String?
  customerType      String?
  customerPhone     String?
  customerEmail     String?
  customerAddress   String?
  agencyName        String?
  collaborator      String?
  operatorOwner     String?
  approver          String?
  adultQty          Int                   @default(0)
  childQty          Int                   @default(0)
  infantQty         Int                   @default(0)
  quantity          Int                   @default(1)
  roomClass         String?
  servicePackage    String?
  transportType     String?
  pickupPoint       String?
  dropoffPoint      String?
  visaDeadline      String?
  seatTotal         Int                   @default(0)
  seatHeld          Int                   @default(0)
  seatSold          Int                   @default(0)
  allowOverbooking  Boolean               @default(false)
  receiveDeadline   DateTime?
  closeDeadline     DateTime?
  totalRevenue      Decimal               @default(0)
  paidAmount        Decimal               @default(0)
  remainingRevenue  Decimal               @default(0)
  totalCost         Decimal               @default(0)
  paidCost          Decimal               @default(0)
  remainingCost     Decimal               @default(0)
  profit            Decimal               @default(0)
  commission        Decimal               @default(0)
  commissionStatus  String                @default("PENDING")
  note              String?
  handoverRequest   String?
  surveyDescription String?
  settledAt         DateTime?
  deletedAt         DateTime?
  guides            OrderGuide[]
  salesItems        OrderSalesItem[]
  operationItems    OrderOperationItem[]
  members           OrderMember[]
  itineraries       OrderItinerary[]
  handoverItems     OrderHandoverItem[]
  surveyQuestions   OrderSurveyQuestion[]
  terms             OrderTerm[]
  files             OrderFile[]
  logs              OrderLog[]
  commissions       CommissionEntry[]
  financeReceipts   FinanceReceiptOrder[]
  financePayments   FinancePayment[]
  financeInvoices   FinanceInvoice[]
  cashflowEntries   FinanceCashflowEntry[]
  customerLedger    CustomerLedgerEntry[]
  supplierLedger    SupplierLedgerEntry[]
  tours             Tour[]
  bookings          Booking[]
  operationVouchers OperationVoucher[]
  allotmentLocks    SupplierAllotmentAllocation[]
  guideSchedules    GuideSchedule[]
  operationForms    OperationForm[]
  fitTours          FitTour[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([type, status])
  @@index([startDate])
  @@index([customerPhone])
  @@index([customerId])
  @@index([deletedAt, updatedAt], map: "idx_order_deleted_updated")
  @@index([deletedAt, startDate], map: "idx_order_deleted_start")
  @@index([deletedAt, status], map: "idx_order_deleted_status")
}

model CommissionRule {
  id            String     @id @default(uuid())
  name          String
  productType   OrderType?
  basis         String     @default("REVENUE")
  milestoneType String     @default("CHECK_IN")
  ratePercent   Decimal    @default(0)
  minRevenue    Decimal?
  maxRevenue    Decimal?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([productType, isActive])
}

model CommissionEntry {
  id               String                  @id @default(uuid())
  orderId          String                  @unique
  order            Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderCode        String
  orderType        OrderType
  tourCode         String?
  customerName     String?
  salesOwner       String?
  team             String?
  department       String?
  branch           String?
  marketGroup      String?
  milestoneType    String                  @default("CHECK_IN")
  milestoneDate    DateTime?
  revenue          Decimal                 @default(0)
  profit           Decimal                 @default(0)
  basis            String                  @default("REVENUE")
  ratePercent      Decimal                 @default(0)
  commissionAmount Decimal                 @default(0)
  status           CommissionStatus        @default(PENDING)
  paymentStatus    CommissionPaymentStatus @default(UNPAID)
  approvedBy       String?
  approvedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  paidAmount       Decimal                 @default(0)
  remainingAmount  Decimal                 @default(0)
  paymentVoucherNo String?
  paidAt           DateTime?
  receiver         String?
  formula          String?
  note             String?
  logs             CommissionLog[]
  payments         CommissionPayment[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([salesOwner])
  @@index([department])
  @@index([branch])
  @@index([marketGroup])
  @@index([milestoneDate])
}

model CommissionLog {
  id           String          @id @default(uuid())
  commissionId String
  commission   CommissionEntry @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  action       String
  actor        String?
  note         String?
  oldStatus    String?
  newStatus    String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([commissionId])
}

model CommissionPayment {
  id           String          @id @default(uuid())
  commissionId String
  commission   CommissionEntry @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  voucherNo    String?
  paidAt       DateTime        @default(now())
  receiver     String?
  amount       Decimal         @default(0)
  note         String?
  createdBy    String?
  createdAt    DateTime        @default(now())

  @@index([commissionId])
}

model FinanceReceipt {
  id                String                 @id @default(uuid())
  receiptCode       String                 @unique
  receiptName       String
  receiptType       FinanceReceiptType     @default(TOUR_PAYMENT)
  documentDate      DateTime?
  transferDate      DateTime?
  paymentDate       DateTime?
  paymentMethod     FinancePaymentMethod   @default(BANK_TRANSFER)
  customerId        String?
  customer          Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tourId            String?
  tour              Tour?                   @relation(fields: [tourId], references: [id], onDelete: SetNull)
  payerName         String?
  payerPhone        String?
  payerEmail        String?
  payerAddress      String?
  reason            String?
  partnerName       String?
  note              String?
  totalAmount       Decimal                @default(0)
  paidBefore        Decimal                @default(0)
  receiptAmount     Decimal                @default(0)
  remainingAmount   Decimal                @default(0)
  approvalStatus    FinanceApprovalStatus  @default(DRAFT)
  lockedAt          DateTime?
  branch            String?
  department        String?
  assignedStaff     String?
  approvedBy        String?
  approvedAt        DateTime?
  cancelledBy       String?
  cancelledAt       DateTime?
  cancelReason      String?
  reversalOfId      String?
  reversalOf        FinanceReceipt?         @relation("FinanceReceiptReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversals         FinanceReceipt[]        @relation("FinanceReceiptReversal")
  collectorSupplier String?
  follower          String?
  tourCreator       String?
  attachmentName    String?
  attachmentUrl     String?
  deletedAt         DateTime?
  orders            FinanceReceiptOrder[]
  cashflowEntries   FinanceCashflowEntry[]
  invoices          FinanceInvoice[]
  customerLedger    CustomerLedgerEntry[]
  createdBy         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([approvalStatus])
  @@index([paymentDate])
  @@index([payerPhone])
  @@index([branch])
  @@index([assignedStaff])
  @@index([customerId])
  @@index([tourId])
  @@index([reversalOfId])
  @@index([deletedAt, updatedAt], map: "idx_fin_receipt_deleted_updated")
  @@index([deletedAt, paymentDate], map: "idx_fin_receipt_deleted_payment")
  @@index([deletedAt, approvalStatus], map: "idx_fin_receipt_deleted_status")
}

model FinanceReceiptOrder {
  id        String         @id @default(uuid())
  receiptId String
  receipt   FinanceReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderCode String?
  tourCode  String?
  tourName  String?
  amount    Decimal        @default(0)
  createdAt DateTime       @default(now())

  @@index([receiptId])
  @@index([orderId])
  @@index([tourCode])
}

model FinancePayment {
  id                 String                 @id @default(uuid())
  voucherCode        String                 @unique
  voucherName        String?
  voucherType        FinancePaymentType     @default(SUPPLIER_PAYMENT)
  documentDate       DateTime?
  transferDate       DateTime?
  paymentDate        DateTime?
  paymentMethod      FinancePaymentMethod   @default(BANK_TRANSFER)
  supplierId         String?
  supplier           Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  operationVoucherId String?
  operationVoucher   OperationVoucher?      @relation(fields: [operationVoucherId], references: [id], onDelete: SetNull)
  orderId            String?
  order              Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tourId             String?
  tour               Tour?                  @relation(fields: [tourId], references: [id], onDelete: SetNull)
  receiverName       String?
  receiverPhone      String?
  receiverEmail      String?
  receiverAddress    String?
  reason             String?
  partnerName        String?
  note               String?
  totalAmount        Decimal                @default(0)
  paymentAmount      Decimal                @default(0)
  remainingAmount    Decimal                @default(0)
  bankAccountName    String?
  bankAccountNumber  String?
  bankName           String?
  isSupplierDeposit  Boolean                @default(false)
  approvalStatus     FinanceApprovalStatus  @default(DRAFT)
  lockedAt           DateTime?
  branch             String?
  department         String?
  assignedStaff      String?
  approvedBy         String?
  approvedAt         DateTime?
  cancelledBy        String?
  cancelledAt        DateTime?
  cancelReason       String?
  reversalOfId       String?
  reversalOf         FinancePayment?        @relation("FinancePaymentReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
