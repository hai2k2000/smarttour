model TourReceipt {
  id            String        @id @default(uuid())
  tourId        String
  tour          Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      TourCustomer? @relation(fields: [customerId], references: [id])
  revenueId     String?
  revenue       TourRevenue?  @relation(fields: [revenueId], references: [id])
  code          String?
  amount        Decimal       @default(0)
  currency      String        @default("VND")
  paymentStatus PaymentStatus @default(UNPAID)
