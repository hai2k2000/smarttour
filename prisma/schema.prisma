model GitTourDetail {
  id               String   @id @default(uuid())
  tourId           String   @unique
  tour             Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  holdCode         String?
  itinerarySummary String?
  /// Legacy snapshot only. Canonical value is TourCustomer where customerType is AGENT; application services must not write this after the common-root migration.
  agentName        String?
  collaborator     String?
  commissionRate   Decimal  @default(0)
  invoiceStatus    String?
  accountCode      String?
  /// Legacy snapshot only. Canonical value is Tour.branch; application services must not write this after the common-root migration.
  branch           String?
  /// Legacy snapshot only. Canonical value is Tour.department; application services must not write this after the common-root migration.
  department       String?
  /// Legacy snapshot only. Canonical value is Tour.customerSource; application services must not write this after the common-root migration.
  customerSource   String?
  fileNote         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LandTourDetail {
  id               String   @id @default(uuid())
  tourId           String   @unique
  tour             Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  /// Legacy snapshot only. Canonical value is TourGuide where guideType is LANDTOUR; application services must not write this after the common-root migration.
  guideName        String?
  comboType        String?
  autoTermsEnabled Boolean  @default(false)
  smartLinkCode    String?
  confirmationNote String?
  /// Legacy snapshot only. Canonical value is TourTerm where language is VI and termType is LANDTOUR; application services must not write this after the common-root migration.
  termsVi          String?
  /// Legacy snapshot only. Canonical value is TourTerm where language is EN and termType is LANDTOUR; application services must not write this after the common-root migration.
  termsEn          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

