model TourAttachment {
  id         String   @id @default(uuid())
  tourId     String
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  step       String?
  fileName   String
  fileUrl    String?
  mimeType   String?
  size       Int?
  uploadedBy String?
  createdAt  DateTime @default(now())
}

model TourNote {
