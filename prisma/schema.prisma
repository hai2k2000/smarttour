  closeAt              DateTime?
  handoverGuideRequest String?
  surveyDescription    String?
  workflowStatus       FitTourWorkflowStatus @default(DRAFT)
  commonCosts          FitCommonCost[]
  hotelCosts           FitHotelCost[]
  privateCosts         FitPrivateCost[]
  budgetServices       FitBudgetService[]
  operationServices    FitOperationService[]
  guides               FitTourGuide[]
  handoverItems        FitHandoverItem[]
  surveyQuestions      FitSurveyQuestion[]
  attachments          FitAttachment[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([customerId])
  @@index([orderId])
}

