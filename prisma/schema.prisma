  supplierId         String?
  supplier           Supplier?         @relation(fields: [supplierId], references: [id])
  supplierServiceId  String?
  supplierService    SupplierService?  @relation(fields: [supplierServiceId], references: [id], onDelete: SetNull)
  serviceType        String
  serviceDate        DateTime?
